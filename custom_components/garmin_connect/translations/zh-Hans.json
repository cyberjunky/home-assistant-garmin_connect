  "services": {
    "set_active_gear": {
      "name": "设置默认装备",
      "description": "将装备设置为某活动类型的默认装备。",
      "fields": {
        "gear_uuid": { "name": "装备 UUID", "description": "装备的 UUID。" },
        "entity_id": { "name": "装备传感器实体", "description": "gear_uuid 的替代项 — 选择一个装备传感器实体。" },
        "activity_type": { "name": "活动类型", "description": "要将装备设为默认的活动类型。" },
        "setting": { "name": "设置", "description": "要应用的装备设置。" }
      }
    },
    "add_hydration": {
      "name": "添加饮水记录",
      "description": "向 Garmin Connect 记录一次饮水。",
      "fields": {
        "value_in_ml": { "name": "饮水量(毫升)", "description": "饮水量(毫升)。负值会从今日饮水量中扣除。" },
        "timestamp": { "name": "时间戳", "description": "测量时间(ISO 8601,默认为当前时间)。" }
      }
    },
    "add_body_composition": {
      "name": "添加身体成分指标",
      "description": "向 Garmin Connect 添加身体成分指标。",
      "fields": {
        "entity_id": { "name": "Garmin Connect 实体", "description": "可选的 Garmin Connect 实体,用于指定接收测量数据的账户。" },
        "weight": { "name": "体重", "description": "体重(千克)。" },
        "timestamp": { "name": "时间戳", "description": "测量记录的时间(默认为当前时间)。" },
        "bmi": { "name": "BMI", "description": "身体质量指数。" },
        "percent_fat": { "name": "体脂率", "description": "体脂百分比。" },
        "percent_hydration": { "name": "水分率", "description": "身体水分百分比。" },
        "visceral_fat_mass": { "name": "内脏脂肪重量", "description": "估计的内脏脂肪重量(千克)。" },
        "bone_mass": { "name": "骨骼重量", "description": "估计的骨骼重量(千克)。" },
        "muscle_mass": { "name": "肌肉重量", "description": "估计的肌肉重量(千克)。" },
        "basal_met": { "name": "基础代谢", "description": "基础代谢率(千卡)。" },
        "active_met": { "name": "活动代谢", "description": "活动代谢率(千卡)。" },
        "physique_rating": { "name": "体型分数", "description": "身体体型分数(1–9)。" },
        "metabolic_age": { "name": "代谢年龄", "description": "估计的代谢年龄(年)。" },
        "visceral_fat_rating": { "name": "内脏脂肪等级", "description": "内脏脂肪等级(1–59)。" }
      }
    },
    "add_blood_pressure": {
      "name": "添加血压记录",
      "description": "向 Garmin Connect 添加一次血压测量。",
      "fields": {
        "systolic": { "name": "收缩压", "description": "收缩压数值。" },
        "diastolic": { "name": "舒张压", "description": "舒张压数值。" },
        "pulse": { "name": "脉率", "description": "脉搏速率。" },
        "timestamp": { "name": "时间戳", "description": "测量记录的时间(默认为当前时间)。" },
        "notes": { "name": "备注", "description": "本次测量的附加备注。" }
      }
    },
    "create_activity": {
      "name": "创建活动",
      "description": "在 Garmin Connect 中创建一项手动活动。",
      "fields": {
        "activity_name": { "name": "活动名称", "description": "活动的名称。" },
        "activity_type": { "name": "活动类型", "description": "活动类型(如 running、cycling)。" },
        "start_datetime": { "name": "开始时间", "description": "活动开始时间(ISO 格式)。" },
        "duration_min": { "name": "时长", "description": "活动时长(分钟)。" },
        "distance_km": { "name": "距离", "description": "活动距离(千米,可选)。" },
        "time_zone": { "name": "时区", "description": "活动的时区。" }
      }
    },
    "upload_activity": {
      "name": "上传活动",
      "description": "向 Garmin Connect 上传活动文件(FIT、GPX、TCX)。",
      "fields": {
        "file_path": { "name": "文件路径", "description": "Home Assistant 系统上活动文件的路径。" }
      }
    },
    "add_gear_to_activity": {
      "name": "为活动添加装备",
      "description": "将装备关联到指定活动。",
      "fields": {
        "activity_id": { "name": "活动 ID", "description": "活动的 ID。" },
        "gear_uuid": { "name": "装备 UUID", "description": "要添加的装备的 UUID。" },
        "entity_id": { "name": "装备传感器实体", "description": "gear_uuid 的替代项 — 选择一个装备传感器实体。" }
      }
    }
  },
