  "services": {
    "set_active_gear": {
      "name": "Set active gear",
      "description": "Set gear as active/default for an activity type.",
      "fields": {
        "gear_uuid": { "name": "Gear UUID", "description": "The UUID of the gear." },
        "entity_id": { "name": "Gear sensor entity", "description": "Alternative to gear_uuid — select a gear sensor entity." },
        "activity_type": { "name": "Activity type", "description": "The activity type for which to set the gear as default." },
        "setting": { "name": "Setting", "description": "The gear setting to apply." }
      }
    },
    "add_body_composition": {
      "name": "Add body composition",
      "description": "Add body composition metrics to Garmin Connect.",
      "fields": {
        "weight": { "name": "Weight", "description": "Weight in kilograms." },
        "timestamp": { "name": "Timestamp", "description": "When the measurement was recorded (defaults to now)." },
        "bmi": { "name": "BMI", "description": "Body Mass Index." },
        "percent_fat": { "name": "Body fat percentage", "description": "Percentage of body fat." },
        "percent_hydration": { "name": "Hydration percentage", "description": "Percentage of body hydration." },
        "visceral_fat_mass": { "name": "Visceral fat mass", "description": "Estimated mass of visceral fat in kilograms." },
        "bone_mass": { "name": "Bone mass", "description": "Estimated mass of bones in kilograms." },
        "muscle_mass": { "name": "Muscle mass", "description": "Estimated mass of muscle in kilograms." },
        "basal_met": { "name": "Basal metabolism", "description": "Basal metabolic rate in kcal." },
        "active_met": { "name": "Active metabolism", "description": "Active metabolic rate in kcal." },
        "physique_rating": { "name": "Physique rating", "description": "Body physique rating (1–9)." },
        "metabolic_age": { "name": "Metabolic age", "description": "Estimated metabolic age in years." },
        "visceral_fat_rating": { "name": "Visceral fat rating", "description": "Visceral fat rating (1–59)." }
      }
    },
    "add_hydration": {
      "name": "Add hydration",
      "description": "Log a hydration intake to Garmin Connect.",
      "fields": {
        "value_in_ml": { "name": "Amount (mL)", "description": "Hydration amount in millilitres. Negative values subtract from today's intake." },
        "timestamp": { "name": "Timestamp", "description": "Measurement time (ISO 8601, defaults to now)." }
      }
    },
    "add_blood_pressure": {
      "name": "Add blood pressure",
      "description": "Add a blood pressure measurement to Garmin Connect.",
      "fields": {
        "systolic": { "name": "Systolic", "description": "Systolic blood pressure value." },
        "diastolic": { "name": "Diastolic", "description": "Diastolic blood pressure value." },
        "pulse": { "name": "Pulse", "description": "Pulse rate." },
        "timestamp": { "name": "Timestamp", "description": "When the measurement was recorded (defaults to now)." },
        "notes": { "name": "Notes", "description": "Additional notes for the measurement." }
      }
    },
    "create_activity": {
      "name": "Create activity",
      "description": "Create a manual activity in Garmin Connect.",
      "fields": {
        "activity_name": { "name": "Activity name", "description": "Name of the activity." },
        "activity_type": { "name": "Activity type", "description": "Type of activity (e.g. running, cycling)." },
        "start_datetime": { "name": "Start date and time", "description": "When the activity started (ISO format)." },
        "duration_min": { "name": "Duration", "description": "Duration of the activity in minutes." },
        "distance_km": { "name": "Distance", "description": "Distance covered in kilometres (optional)." },
        "time_zone": { "name": "Time zone", "description": "Time zone for the activity." }
      }
    },
    "upload_activity": {
      "name": "Upload activity",
      "description": "Upload an activity file (FIT, GPX, TCX) to Garmin Connect.",
      "fields": {
        "file_path": { "name": "File path", "description": "Path to the activity file on the Home Assistant system." }
      }
    },
    "add_gear_to_activity": {
      "name": "Add gear to activity",
      "description": "Associate gear with a specific activity.",
      "fields": {
        "activity_id": { "name": "Activity ID", "description": "The ID of the activity." },
        "gear_uuid": { "name": "Gear UUID", "description": "The UUID of the gear to add." },
        "entity_id": { "name": "Gear sensor entity", "description": "Alternative to gear_uuid — select a gear sensor entity." }
      }
    }
  },
