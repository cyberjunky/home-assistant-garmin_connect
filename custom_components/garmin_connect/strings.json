    "create_activity_failed": { "message": "Failed to create activity: {error}" },
    "entity_not_found": { "message": "Entity not found: {entity_id}" },
    "file_not_found": { "message": "File not found: {file_path}" },
    "gear_uuid_not_found": { "message": "Entity {entity_id} does not have a gear_uuid attribute." },
    "integration_not_loaded": { "message": "Garmin Connect integration is not loaded." },
    "login_failed": { "message": "Failed to log in to Garmin Connect." },
    "no_gear_specified": { "message": "No gear specified. Provide either a gear sensor entity or a gear_uuid." },
    "no_integration_configured": { "message": "Garmin Connect integration is not configured." },
